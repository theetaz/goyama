  "body": {
    "en": "Transplant 25–30-day-old seedlings at 90 cm × 60 cm spacing. Apply the basal fertiliser mix at planting: Urea 75 kg/ha, TSP 325 kg/ha, MOP 85 kg/ha.",
    "si": "දින 25–30 ක් වයසැති පැළ 90 cm × 60 cm පරතරයකින් සිටුවන්න. සිටුවන විට මුල් පොහොර මිශ්‍රණය යොදන්න: යූරියා හෙක්ටයාරයට 75 kg, TSP 325 kg, MOP 85 kg.",
    "ta": "25–30 நாட்கள் வயதான நாற்றுகளை 90 cm × 60 cm இடைவெளியில் நடவு செய்யவும். நடவு நேரத்தில் அடிப்படை உரக் கலவை வழங்கவும்: யூரியா ஹெக்டேருக்கு 75 kg, TSP 325 kg, MOP 85 kg.",
    "si_status": "machine_draft",
    "ta_status": "machine_draft"
  },
  "inputs": [
    {"type": "fertilizer", "name": {"en": "Urea", "si": "යූරියා", "ta": "யூரியா", "si_status": "machine_draft", "ta_status": "machine_draft"}, "amount": 75, "unit": "kg", "per_unit_area": "hectare"},
    {"type": "fertilizer", "name": {"en": "Triple Super Phosphate (TSP)", "si": "TSP පොස්පේට්", "ta": "டிரிப்பிள் சூப்பர் பாஸ்பேட் (TSP)", "si_status": "machine_draft", "ta_status": "machine_draft"}, "amount": 325, "unit": "kg", "per_unit_area": "hectare"},
