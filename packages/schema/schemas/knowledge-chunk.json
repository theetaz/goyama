{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://goyama.lk/schemas/knowledge-chunk.json",
  "title": "KnowledgeChunk",
  "description": "One retrievable unit of unstructured agronomic knowledge — a paragraph from an article, a segment of a video transcript, an agronomist's field note. Lives alongside structured canonical rows; referenced by entity_refs. The retrieval surface for the future chat agent.",
  "type": "object",
  "required": ["slug", "source_slug", "language", "body", "authority", "status"],
  "properties": {
    "slug": { "$ref": "common.json#/$defs/Slug" },
    "source_slug": { "$ref": "common.json#/$defs/Slug" },
    "chunk_idx": { "type": "integer", "minimum": 0, "default": 0 },
    "language": { "$ref": "common.json#/$defs/Locale" },
    "title": { "type": "string" },
    "body": { "type": "string", "minLength": 1 },
    "body_translated": { "$ref": "common.json#/$defs/I18nString" },
    "entity_refs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "slug"],
        "properties": {
          "type": {
            "type": "string",
            "enum": ["crop", "variety", "disease", "pest", "remedy", "aez", "district", "cultivation_plan"]
          },
          "slug": { "type": "string" }
        }
      }
    },
    "authority": { "$ref": "common.json#/$defs/AuthorityLevel" },
    "applies_to_aez_codes": {
      "type": "array",
      "items": { "type": "string" }
    },
    "applies_to_countries": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Z]{2}(-[A-Z0-9]{1,3})?$"
      },
      "description": "ISO 3166-1 alpha-2 country code, optionally with a 3166-2 subdivision (e.g. 'LK', 'IN', 'IN-TN'). Defaults to ['LK']."
    },
    "topic_tags": {
      "type": "array",
      "items": { "type": "string" }
    },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "quote": { "type": "string" },
    "status": { "$ref": "common.json#/$defs/Status" },
    "field_provenance": {
      "type": "object",
      "description": "Free-form authoring provenance (who/when/how this chunk was extracted)."
    }
  },
  "additionalProperties": false
}
