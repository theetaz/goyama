# Copy to .env and fill. Do not commit .env.

# Storage paths (relative or absolute)
CROPDOC_RAW_DIR=./data/raw
CROPDOC_STAGING_DIR=./data/staging
CROPDOC_CACHE_DIR=./data/cache

# HTTP
CROPDOC_USER_AGENT="CropDocBot/0.0.1 (+https://cropdoc.lk/bot)"
CROPDOC_HTTP_TIMEOUT_SEC=30

# LLM provider: "anthropic" | "none"
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=

# Default model for extraction
LLM_MODEL=claude-sonnet-4-6

# Postgres (required for `cropdoc ingest`)
DATABASE_URL=postgresql://cropdoc:cropdoc@localhost:5432/cropdoc

# Structured logging level
LOG_LEVEL=INFO
